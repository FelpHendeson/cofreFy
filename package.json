{
  "name": "cofrefy",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @cofrefy/web dev",
    "build": "pnpm --filter @cofrefy/web build",
    "start": "pnpm --filter @cofrefy/web start",
    "lint": "pnpm --filter @cofrefy/web lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter @cofrefy/web db:generate",
    "db:push": "pnpm --filter @cofrefy/web db:push",
    "db:studio": "pnpm --filter @cofrefy/web db:studio",
    "db:validate": "pnpm --filter @cofrefy/web db:validate",
    "db:migrate": "pnpm --filter @cofrefy/web db:migrate",
    "db:seed": "pnpm --filter @cofrefy/web db:seed"
  },
  "engines": {
    "node": ">=20"
  }
}
