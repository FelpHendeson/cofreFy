# =============================================================================
# CofreFy — Variáveis de ambiente
# =============================================================================
#
# Uso:
#   pnpm setup:env
#
# Isso copia este arquivo para:
#   - .env              (raiz — Docker Compose)
#   - apps/web/.env     (Next.js + Prisma)
#
# =============================================================================


# -----------------------------------------------------------------------------
# MySQL — Docker Compose (raiz do projeto)
# -----------------------------------------------------------------------------
# Usado por: docker compose up
# -----------------------------------------------------------------------------

MYSQL_DATABASE=cofrefy
MYSQL_USER=cofrefy_user
MYSQL_PASSWORD=cofrefy_password
MYSQL_ROOT_PASSWORD=root_password


# -----------------------------------------------------------------------------
# Prisma — Banco de dados (apps/web)
# -----------------------------------------------------------------------------
# Usado por: pnpm db:migrate | db:push | db:seed | db:studio
# -----------------------------------------------------------------------------

# Conexão principal da aplicação
DATABASE_URL=mysql://cofrefy_user:cofrefy_password@localhost:3306/cofrefy

# Banco shadow para migrations locais (credencial root)
# Necessário apenas para: pnpm db:migrate
SHADOW_DATABASE_URL=mysql://root:root_password@localhost:3306/cofrefy_shadow


# -----------------------------------------------------------------------------
# Next.js — Servidor local (apps/web)
# -----------------------------------------------------------------------------
# Usado por: pnpm dev | pnpm start
# Padrão: 3000 — altere se a porta já estiver em uso (ex.: 3001)
# -----------------------------------------------------------------------------

PORT=3000
